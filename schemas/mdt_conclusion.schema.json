{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "MDT Conclusion",
  "type": "object",
  "required": ["case_id", "status", "recommendations", "unresolved_issues", "next_review_at"],
  "properties": {
    "case_id": { "type": "string" },
    "status": { "type": "string", "enum": ["consensus", "majority", "unresolved", "escalated"] },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["topic", "recommendation", "evidence_level"],
        "properties": {
          "topic": { "type": "string" },
          "recommendation": { "type": "string" },
          "evidence_level": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "unresolved_issues": { "type": "array", "items": { "type": "string" } },
    "next_review_at": { "type": "string", "format": "date-time" }
  }
}
